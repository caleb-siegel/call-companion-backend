# Database Connection URL (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT signing secret key
JWT_SECRET_KEY=your-secret-key-change-me

# Optional: CORS allowed origins
FRONTEND_URL=http://localhost:5173

# Optional: SMTP Email Server Settings (If omitted, reset links are printed to backend console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@callcompanion.com

